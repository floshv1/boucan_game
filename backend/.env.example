# Boucan — backend. No database: state is in-memory only.
PORT_BACKEND=8200

# Comma-separated allowed origins for the HTTP API (and the WebSocket origin
# guard). Leave unset to default to FRONTEND_URL — the app only talks to the
# backend same-origin (via the Next proxy) so it never needs a wildcard. A "*"
# here also disables the cross-site WebSocket guard, so only use it knowingly.
# CORS_ORIGINS=

# Spotify OAuth (Phase 3 — Blindtest). Get credentials at
# https://developer.spotify.com/dashboard. The redirect URI must be registered
# there exactly as written here.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8200/auth/spotify/callback

# URL of the frontend (used for post-OAuth redirects).
FRONTEND_URL=http://127.0.0.1:3200

# Phase 4 — pack editor storage (optional). Question packs are saved as JSON in
# PACKS_DIR and uploaded images in MEDIA_DIR (relative to the backend workdir).
# In Docker these are mounted as named volumes (see compose.yml) so they persist.
# PACKS_DIR=packs
# MEDIA_DIR=media
