# Backend port the browser connects to over WebSocket. The host part is derived
# from the page URL, so phones reach the server at the same IP they loaded from.
NEXT_PUBLIC_BACKEND_PORT=8200

# Server-side target for the /api/* proxy (Next rewrites). In Docker, use the
# backend service name, e.g. http://backend:8200.
BACKEND_URL=http://localhost:8200
